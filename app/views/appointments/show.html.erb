<div class="mb-3">
  <%= link_to "← Back to Appointments", appointments_path, class: "btn btn-outline-secondary btn-sm" %>
</div>

<% status_colors = { 0 => "primary", 1 => "warning", 2 => "success", 3 => "danger" } %>

<div class="card shadow-sm mb-4">
  <div class="card-header bg-success text-white">
    <h2 class="h5 mb-0">Appointment — <%= @appointment.date.strftime("%B %d, %Y %H:%M") %></h2>
  </div>
  <ul class="list-group list-group-flush">
    <li class="list-group-item"><strong>Pet:</strong> <%= link_to @appointment.pet.name, pet_path(@appointment.pet) %></li>
    <li class="list-group-item"><strong>Vet:</strong> <%= link_to "#{@appointment.vet.first_name} #{@appointment.vet.last_name}", vet_path(@appointment.vet) %></li>
    <li class="list-group-item"><strong>Reason:</strong> <%= @appointment.reason %></li>
    <li class="list-group-item">
      <strong>Status:</strong>
      <span class="badge bg-<%= status_colors[@appointment.status] %>">
        <%= AppointmentsController::STATUSES[@appointment.status] %>
      </span>
    </li>
  </ul>
</div>

<h4>Treatments</h4>
<% if @appointment.treatments.any? %>
  <table class="table table-bordered table-hover bg-white shadow-sm">
    <thead class="table-success">
      <tr>
        <th>Name</th>
        <th>Medication</th>
        <th>Dosage</th>
        <th>Administered At</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      <% @appointment.treatments.each do |treatment| %>
        <tr>
          <td><%= treatment.name %></td>
          <td><%= treatment.medication %></td>
          <td><%= treatment.dosage %></td>
          <td><%= treatment.administered_at.strftime("%B %d, %Y %H:%M") %></td>
          <td><%= treatment.notes %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-muted">No treatments recorded for this appointment.</p>
<% end %>
