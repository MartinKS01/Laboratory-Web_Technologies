<div class="mb-3">
  <%= link_to "← Back to Pets", pets_path, class: "btn btn-outline-secondary btn-sm" %>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-header bg-success text-white">
    <h2 class="h5 mb-0"><%= @pet.name %></h2>
  </div>
  <ul class="list-group list-group-flush">
    <li class="list-group-item"><strong>Species:</strong> <%= @pet.species %></li>
    <li class="list-group-item"><strong>Breed:</strong> <%= @pet.breed %></li>
    <li class="list-group-item"><strong>Date of Birth:</strong> <%= @pet.date_of_birth.strftime("%B %d, %Y") %></li>
    <li class="list-group-item"><strong>Weight:</strong> <%= @pet.weight %> kg</li>
    <li class="list-group-item"><strong>Owner:</strong> <%= link_to "#{@pet.owner.first_name} #{@pet.owner.last_name}", owner_path(@pet.owner) %></li>
  </ul>
</div>

<h4>Appointments</h4>
<% if @pet.appointments.any? %>
  <table class="table table-bordered table-hover bg-white shadow-sm">
    <thead class="table-success">
      <tr>
        <th>Date</th>
        <th>Reason</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% @pet.appointments.each do |appointment| %>
        <tr>
          <td><%= link_to appointment.date.strftime("%B %d, %Y %H:%M"), appointment_path(appointment) %></td>
          <td><%= appointment.reason %></td>
          <td><%= AppointmentsController::STATUSES[appointment.status] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-muted">No appointments found.</p>
<% end %>
