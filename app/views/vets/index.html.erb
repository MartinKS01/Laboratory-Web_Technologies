<h1 class="mb-4">Veterinarians</h1>

<table class="table table-bordered table-hover bg-white shadow-sm">
  <thead class="table-success">
    <tr>
      <th>Full Name</th>
      <th>Email</th>
      <th>Specialization</th>
    </tr>
  </thead>
  <tbody>
    <% @vets.each do |vet| %>
      <tr>
        <td><%= link_to "#{vet.first_name} #{vet.last_name}", vet_path(vet) %></td>
        <td><%= vet.email %></td>
        <td><%= vet.specialization %></td>
      </tr>
    <% end %>
  </tbody>
</table>
