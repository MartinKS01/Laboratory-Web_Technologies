<div class="mb-3">
  <%= link_to "← Back to Vets", vets_path, class: "btn btn-outline-secondary btn-sm" %>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-header bg-success text-white">
    <h2 class="h5 mb-0"><%= "#{@vet.first_name} #{@vet.last_name}" %></h2>
  </div>
  <ul class="list-group list-group-flush">
    <li class="list-group-item"><strong>Email:</strong> <%= @vet.email %></li>
    <li class="list-group-item"><strong>Phone:</strong> <%= @vet.phone %></li>
    <li class="list-group-item"><strong>Specialization:</strong> <%= @vet.specialization %></li>
  </ul>
</div>

<h4>Appointments</h4>
<% if @vet.appointments.any? %>
  <table class="table table-bordered table-hover bg-white shadow-sm">
    <thead class="table-success">
      <tr>
        <th>Date</th>
        <th>Pet</th>
        <th>Reason</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% @vet.appointments.each do |appointment| %>
        <tr>
          <td><%= link_to appointment.date.strftime("%B %d, %Y %H:%M"), appointment_path(appointment) %></td>
          <td><%= link_to appointment.pet.name, pet_path(appointment.pet) %></td>
          <td><%= appointment.reason %></td>
          <td><%= AppointmentsController::STATUSES[appointment.status] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-muted">No appointments found.</p>
<% end %>
